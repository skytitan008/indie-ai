{
  "name": "indie-ai-desktop",
  "version": "1.0.0",
  "description": "不依赖大模型的独立思考 AI 系统 - 桌面版",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "ai",
    "reinforcement-learning",
    "q-learning",
    "sarsa",
    "multi-agent",
    "no-llm",
    "symbolic-ai",
    "autonomous-agent",
    "decision-making"
  ],
  "author": "skytitan008",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.indieai.desktop",
    "productName": "Indie AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "../web/**/*",
      "../demo/**/*",
      "../src/**/*.py",
      "../run.sh",
      "../requirements.txt"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
