{
  "name": "indie-ai-helper",
  "displayName": "Indie AI Helper",
  "description": "不依赖大模型的独立思考 AI 助手 - 代码格式化、任务管理、实验运行",
  "version": "1.0.0",
  "publisher": "skytitan008",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Snippets"
  ],
  "activationEvents": [
    "onCommand:indie-ai.formatCode",
    "onCommand:indie-ai.runExperiment",
    "onCommand:indie-ai.showStatus"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "indie-ai.formatCode",
        "title": "Indie AI: 格式化代码"
      },
      {
        "command": "indie-ai.runExperiment",
        "title": "Indie AI: 运行实验"
      },
      {
        "command": "indie-ai.showStatus",
        "title": "Indie AI: 显示状态"
      },
      {
        "command": "indie-ai.runTask",
        "title": "Indie AI: 运行任务"
      },
      {
        "command": "indie-ai.generateReport",
        "title": "Indie AI: 生成日报"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == python",
          "command": "indie-ai.formatCode",
          "group": "IndieAI@1"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceLangId == python",
          "command": "indie-ai.formatCode",
          "group": "IndieAI@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "indie-ai.formatCode",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorTextFocus"
      },
      {
        "command": "indie-ai.runExperiment",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Indie AI Helper",
      "properties": {
        "indieAi.projectPath": {
          "type": "string",
          "default": "",
          "description": "Indie AI 项目路径"
        },
        "indieAi.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Python 解释器路径"
        },
        "indieAi.autoFormat": {
          "type": "boolean",
          "default": false,
          "description": "保存时自动格式化"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/glob": "^8.1.0",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "glob": "^10.3.10",
    "typescript": "^5.3.2",
    "@vscode/test-electron": "^2.3.8"
  },
  "dependencies": {
    "child_process": "^1.0.2"
  }
}
